# 本机编辑器和临时配置
.vscode/
.idea/
*.code-workspace
.codex

# Python 运行缓存
__pycache__/
*.py[cod]
*.pyc.*

# 本地临时导出和检查缓存
tmp/

# 本地数据、实验结果和训练输出
experiments/**/results/
src/calibration/captures/
src/calibration/output/
src/Identification_code/raw_data/
src/Identification_code/datasets/
src/Identification_code/test_picture_video/
